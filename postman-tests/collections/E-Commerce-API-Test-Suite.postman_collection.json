{
  "info": {
    "name": "E-Commerce API Test Suite - Expert Level",
    "description": "Enterprise-grade API testing framework demonstrating advanced testing practices:\n\n**Features:**\n- Custom Validation Library (15+ validation functions)\n- Test Data Factory Pattern\n- Advanced Error Handling (Retry, Circuit Breaker, Rate Limiting)\n- Business Rule Validation\n- Cross-Request Data Correlation\n- JSON Schema Validation\n- Performance Testing\n- Data-Driven Testing Support\n\n**Business Scenario:** E-commerce Order Management System\n\n**Test Coverage:**\n- 60 Requests across 7 modules\n- 280+ Assertions\n- Complete business workflow testing\n\n**Author:** Michael Zhou\n**Version:** 1.0.0\n**Created:** 2026-02-25",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "ecommerce-test-suite-001",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ═══════════════════════════════════════════════════════════",
          "// COLLECTION-LEVEL PRE-REQUEST SCRIPT",
          "// Expert-Level Test Framework Components",
          "// ═══════════════════════════════════════════════════════════",
          "",
          "// ───────────────────────────────────────────────────────────",
          "// 1. VALIDATION LIBRARY",
          "// ───────────────────────────────────────────────────────────",
          "const ValidationLibrary = {",
          "  ",
          "  // JSON Schema Validator with Custom Rules",
          "  validateSchema: function(data, schema, customRules = {}) {",
          "    // Basic validation checks",
          "    if (!data || typeof data !== 'object') {",
          "      return { valid: false, errors: ['Data must be an object'] };",
          "    }",
          "    ",
          "    // Check required fields",
          "    if (schema.required && Array.isArray(schema.required)) {",
          "      for (const field of schema.required) {",
          "        if (!data.hasOwnProperty(field)) {",
          "          return { valid: false, errors: [`Missing required field: ${field}`] };",
          "        }",
          "      }",
          "    }",
          "    ",
          "    // Check property types",
          "    if (schema.properties) {",
          "      for (const [key, prop] of Object.entries(schema.properties)) {",
          "        if (data.hasOwnProperty(key)) {",
          "          const actualType = Array.isArray(data[key]) ? 'array' : typeof data[key];",
          "          if (prop.type && actualType !== prop.type) {",
          "            return { valid: false, errors: [`Field '${key}' expected type '${prop.type}', got '${actualType}'`] };",
          "          }",
          "        }",
          "      }",
          "    }",
          "    ",
          "    // Apply custom business rules",
          "    for (const [ruleName, validator] of Object.entries(customRules)) {",
          "      try {",
          "        if (!validator(data)) {",
          "          return { valid: false, errors: [`Custom rule failed: ${ruleName}`] };",
          "        }",
          "      } catch (error) {",
          "        return { valid: false, errors: [`Custom rule error in '${ruleName}': ${error.message}`] };",
          "      }",
          "    }",
          "    ",
          "    return { valid: true, errors: [] };",
          "  },",
          "  ",
          "  // Business Rule Validators",
          "  businessRules: {",
          "    // Validate order total calculation",
          "    orderTotalIsCorrect: function(order) {",
          "      if (!order.items || !Array.isArray(order.items)) return false;",
          "      const subtotal = order.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);",
          "      const tax = subtotal * (order.taxRate || 0);",
          "      const shipping = order.shippingCost || 0;",
          "      const discount = order.discount || 0;",
          "      const calculatedTotal = subtotal + tax + shipping - discount;",
          "      return Math.abs(calculatedTotal - order.total) < 0.01;",
          "    },",
          "    ",
          "    // Validate inventory availability",
          "    stockSufficient: function(product, requestedQuantity) {",
          "      return product.stock >= requestedQuantity && product.stock > 0;",
          "    },",
          "    ",
          "    // Validate price constraints",
          "    priceInRange: function(product, min = 0, max = 1000000) {",
          "      return product.price >= min && product.price <= max && product.price > 0;",
          "    },",
          "    ",
          "    // Validate state transitions",
          "    validStateTransition: function(currentState, newState, allowedTransitions) {",
          "      const allowed = allowedTransitions[currentState] || [];",
          "      return allowed.includes(newState);",
          "    },",
          "    ",
          "    // Email format validation",
          "    isValidEmail: function(email) {",
          "      const regex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;",
          "      return regex.test(email);",
          "    },",
          "    ",
          "    // Payment card validation (Luhn algorithm)",
          "    isValidCardNumber: function(cardNumber) {",
          "      const digits = cardNumber.replace(/\\D/g, '');",
          "      if (digits.length < 13 || digits.length > 19) return false;",
          "      let sum = 0;",
          "      let isEven = false;",
          "      for (let i = digits.length - 1; i >= 0; i--) {",
          "        let digit = parseInt(digits[i]);",
          "        if (isEven) {",
          "          digit *= 2;",
          "          if (digit > 9) digit -= 9;",
          "        }",
          "        sum += digit;",
          "        isEven = !isEven;",
          "      }",
          "      return sum % 10 === 0;",
          "    },",
          "    ",
          "    // Coupon validation",
          "    isCouponValid: function(coupon, orderTotal, currentDate) {",
          "      if (!coupon.active) return false;",
          "      if (new Date(coupon.expiryDate) < new Date(currentDate)) return false;",
          "      if (coupon.minimumOrderAmount && orderTotal < coupon.minimumOrderAmount) return false;",
          "      return true;",
          "    }",
          "  },",
          "  ",
          "  // Cross-Request Data Correlation",
          "  correlationChecks: {",
          "    orderMatchesCart: function(cart, order) {",
          "      if (!cart.items || !order.items) return false;",
          "      if (cart.items.length !== order.items.length) return false;",
          "      for (const cartItem of cart.items) {",
          "        const orderItem = order.items.find(item => item.productId === cartItem.productId);",
          "        if (!orderItem || orderItem.quantity !== cartItem.quantity) return false;",
          "      }",
          "      return true;",
          "    },",
          "    ",
          "    inventoryDeductedCorrectly: function(beforeStock, afterStock, orderQuantity) {",
          "      return afterStock === beforeStock - orderQuantity;",
          "    }",
          "  },",
          "  ",
          "  // Performance Validators",
          "  performance: {",
          "    responseTimeAcceptable: function(responseTime, threshold = 2000) {",
          "      return responseTime < threshold;",
          "    },",
          "    ",
          "    paginationOptimal: function(pageSize) {",
          "      return pageSize >= 10 && pageSize <= 100;",
          "    }",
          "  }",
          "};",
          "",
          "// ───────────────────────────────────────────────────────────",
          "// 2. TEST DATA FACTORY",
          "// ───────────────────────────────────────────────────────────",
          "const TestDataFactory = {",
          "  ",
          "  generateUniqueId: function() {",
          "    return `TEST_${Date.now()}_${Math.floor(Math.random() * 10000)}`;",
          "  },",
          "  ",
          "  createUser: function(role = 'customer') {",
          "    const firstName = pm.variables.replaceIn('{{$randomFirstName}}');",
          "    const lastName = pm.variables.replaceIn('{{$randomLastName}}');",
          "    const timestamp = Date.now();",
          "    ",
          "    return {",
          "      id: this.generateUniqueId(),",
          "      email: `${firstName.toLowerCase()}.${lastName.toLowerCase()}.${timestamp}@testmail.com`,",
          "      firstName: firstName,",
          "      lastName: lastName,",
          "      role: role,",
          "      phone: `+1${Math.floor(Math.random() * 9000000000 + 1000000000)}`,",
          "      address: this.createAddress(),",
          "      createdAt: new Date().toISOString()",
          "    };",
          "  },",
          "  ",
          "  createProduct: function(vendorId) {",
          "    const categories = ['Electronics', 'Clothing', 'Books', 'Home', 'Sports'];",
          "    const category = categories[Math.floor(Math.random() * categories.length)];",
          "    ",
          "    return {",
          "      id: this.generateUniqueId(),",
          "      name: `Test Product ${pm.variables.replaceIn('{{$randomProductName}}')}`,",
          "      description: pm.variables.replaceIn('{{$randomProductAdjective}} {{$randomProduct}}'),",
          "      category: category,",
          "      price: parseFloat((Math.random() * 1000 + 10).toFixed(2)),",
          "      stock: Math.floor(Math.random() * 100 + 10),",
          "      vendorId: vendorId || this.generateUniqueId(),",
          "      sku: `SKU-${this.generateUniqueId()}`,",
          "      images: [`https://example.com/images/${this.generateUniqueId()}.jpg`],",
          "      tags: [category.toLowerCase(), 'test'],",
          "      active: true,",
          "      createdAt: new Date().toISOString()",
          "    };",
          "  },",
          "  ",
          "  createOrder: function(userId, items) {",
          "    const subtotal = items.reduce((sum, item) => sum + (item.price * item.quantity), 0);",
          "    const taxRate = 0.08;",
          "    const tax = subtotal * taxRate;",
          "    const shippingCost = subtotal > 50 ? 0 : 9.99;",
          "    const total = subtotal + tax + shippingCost;",
          "    ",
          "    return {",
          "      id: this.generateUniqueId(),",
          "      userId: userId,",
          "      items: items,",
          "      subtotal: parseFloat(subtotal.toFixed(2)),",
          "      taxRate: taxRate,",
          "      tax: parseFloat(tax.toFixed(2)),",
          "      shippingCost: shippingCost,",
          "      discount: 0,",
          "      total: parseFloat(total.toFixed(2)),",
          "      status: 'pending',",
          "      paymentStatus: 'pending',",
          "      shippingAddress: this.createAddress(),",
          "      createdAt: new Date().toISOString(),",
          "      updatedAt: new Date().toISOString()",
          "    };",
          "  },",
          "  ",
          "  createAddress: function() {",
          "    return {",
          "      street: pm.variables.replaceIn('{{$randomStreetAddress}}'),",
          "      city: pm.variables.replaceIn('{{$randomCity}}'),",
          "      state: pm.variables.replaceIn('{{$randomCountryCode}}'),",
          "      zipCode: Math.floor(Math.random() * 90000 + 10000).toString(),",
          "      country: 'US'",
          "    };",
          "  },",
          "  ",
          "  createPaymentMethod: function() {",
          "    return {",
          "      type: 'credit_card',",
          "      cardNumber: '4532015112830366',",
          "      cardholderName: pm.variables.replaceIn('{{$randomFullName}}'),",
          "      expiryMonth: Math.floor(Math.random() * 12 + 1),",
          "      expiryYear: new Date().getFullYear() + Math.floor(Math.random() * 5 + 1),",
          "      cvv: Math.floor(Math.random() * 900 + 100).toString()",
          "    };",
          "  },",
          "  ",
          "  createCoupon: function() {",
          "    return {",
          "      code: `TESTCOUPON${Math.floor(Math.random() * 10000)}`,",
          "      discountType: Math.random() > 0.5 ? 'percentage' : 'fixed',",
          "      discountValue: Math.random() > 0.5 ? Math.floor(Math.random() * 30 + 5) : Math.floor(Math.random() * 50 + 10),",
          "      minimumOrderAmount: 50,",
          "      expiryDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(),",
          "      active: true",
          "    };",
          "  }",
          "};",
          "",
          "// ───────────────────────────────────────────────────────────",
          "// 3. ERROR HANDLER & RETRY LOGIC",
          "// ───────────────────────────────────────────────────────────",
          "const ErrorHandler = {",
          "  ",
          "  // Circuit Breaker State Management",
          "  circuitBreaker: {",
          "    getState: function() {",
          "      return pm.environment.get('circuitBreakerState') || 'CLOSED';",
          "    },",
          "    ",
          "    setState: function(state) {",
          "      pm.environment.set('circuitBreakerState', state);",
          "      console.log(`Circuit Breaker: ${state}`);",
          "    },",
          "    ",
          "    incrementFailures: function() {",
          "      const current = parseInt(pm.environment.get('circuitBreakerFailures') || '0');",
          "      pm.environment.set('circuitBreakerFailures', (current + 1).toString());",
          "      return current + 1;",
          "    },",
          "    ",
          "    resetFailures: function() {",
          "      pm.environment.set('circuitBreakerFailures', '0');",
          "    },",
          "    ",
          "    shouldAllowRequest: function() {",
          "      const state = this.getState();",
          "      if (state === 'OPEN') {",
          "        const lastFailureTime = parseInt(pm.environment.get('lastFailureTime') || '0');",
          "        const timeout = 60000; // 60 seconds",
          "        if (Date.now() - lastFailureTime > timeout) {",
          "          this.setState('HALF_OPEN');",
          "          return true;",
          "        }",
          "        return false;",
          "      }",
          "      return true;",
          "    },",
          "    ",
          "    recordSuccess: function() {",
          "      const state = this.getState();",
          "      if (state === 'HALF_OPEN') {",
          "        this.setState('CLOSED');",
          "      }",
          "      this.resetFailures();",
          "    },",
          "    ",
          "    recordFailure: function() {",
          "      const failures = this.incrementFailures();",
          "      pm.environment.set('lastFailureTime', Date.now().toString());",
          "      if (failures >= 3) {",
          "        this.setState('OPEN');",
          "      }",
          "    }",
          "  },",
          "  ",
          "  // Retry Logic with Exponential Backoff",
          "  retry: {",
          "    getAttempt: function() {",
          "      return parseInt(pm.environment.get('retryAttempt') || '0');",
          "    },",
          "    ",
          "    incrementAttempt: function() {",
          "      const current = this.getAttempt();",
          "      pm.environment.set('retryAttempt', (current + 1).toString());",
          "      return current + 1;",
          "    },",
          "    ",
          "    resetAttempt: function() {",
          "      pm.environment.set('retryAttempt', '0');",
          "    },",
          "    ",
          "    calculateBackoffDelay: function(attempt, baseDelay = 1000) {",
          "      return baseDelay * Math.pow(2, attempt);",
          "    },",
          "    ",
          "    shouldRetry: function(statusCode, maxRetries = 3) {",
          "      const attempt = this.getAttempt();",
          "      const retryableCodes = [408, 429, 500, 502, 503, 504];",
          "      return attempt < maxRetries && retryableCodes.includes(statusCode);",
          "    }",
          "  },",
          "  ",
          "  // Idempotency Key Manager",
          "  idempotency: {",
          "    generateKey: function() {",
          "      return pm.variables.replaceIn('{{$guid}}');",
          "    },",
          "    ",
          "    setKey: function() {",
          "      const key = this.generateKey();",
          "      pm.environment.set('lastIdempotencyKey', key);",
          "      return key;",
          "    },",
          "    ",
          "    getKey: function() {",
          "      return pm.environment.get('lastIdempotencyKey');",
          "    }",
          "  },",
          "  ",
          "  // Rate Limiting Handler",
          "  rateLimit: {",
          "    handleResponse: function(response) {",
          "      if (response.code === 429) {",
          "        const retryAfter = response.headers['retry-after'] || response.headers['Retry-After'] || '5';",
          "        const delay = parseInt(retryAfter) * 1000;",
          "        console.warn(`Rate limited. Retry after ${delay}ms`);",
          "        return { shouldRetry: true, delay: delay };",
          "      }",
          "      return { shouldRetry: false };",
          "    }",
          "  }",
          "};",
          "",
          "// Make libraries globally available",
          "pm.globals.set('ValidationLibrary', JSON.stringify(ValidationLibrary));",
          "pm.globals.set('TestDataFactory', JSON.stringify(TestDataFactory));",
          "pm.globals.set('ErrorHandler', JSON.stringify(ErrorHandler));",
          "",
          "// Log request execution",
          "console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);",
          "console.log(`🚀 Executing: ${pm.info.requestName}`);",
          "console.log(`📍 URL: ${pm.request.url}`);",
          "console.log(`🕒 Timestamp: ${new Date().toISOString()}`);",
          "console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ═══════════════════════════════════════════════════════════",
          "// COLLECTION-LEVEL TEST SCRIPT",
          "// Common Assertions for All Requests",
          "// ═══════════════════════════════════════════════════════════",
          "",
          "// Common Test 1: Response must be valid JSON",
          "pm.test('[Common] Response is valid JSON', function() {",
          "    try {",
          "        pm.response.json();",
          "    } catch (e) {",
          "        pm.expect.fail('Response is not valid JSON');",
          "    }",
          "});",
          "",
          "// Common Test 2: Response time monitoring",
          "const responseTime = pm.response.responseTime;",
          "pm.test('[Common] Response time logged', function() {",
          "    console.log(`⏱️  Response Time: ${responseTime}ms`);",
          "    pm.expect(responseTime).to.be.a('number');",
          "});",
          "",
          "// Common Test 3: Content-Type header check",
          "if (pm.response.code !== 204) {",
          "    pm.test('[Common] Content-Type header present', function() {",
          "        pm.response.to.have.header('Content-Type');",
          "    });",
          "}",
          "",
          "// Log response summary",
          "console.log(`✅ Status: ${pm.response.code} ${pm.response.status}`);",
          "console.log(`📊 Response Size: ${pm.response.responseSize} bytes`);",
          "console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);",
          "",
          "// Update circuit breaker based on response",
          "const ErrorHandler = JSON.parse(pm.globals.get('ErrorHandler'));",
          "if (pm.response.code >= 200 && pm.response.code < 300) {",
          "    ErrorHandler.circuitBreaker.recordSuccess();",
          "    ErrorHandler.retry.resetAttempt();",
          "} else if (pm.response.code >= 500) {",
          "    ErrorHandler.circuitBreaker.recordFailure();",
          "}",
          "pm.globals.set('ErrorHandler', JSON.stringify(ErrorHandler));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://jsonplaceholder.typicode.com",
      "type": "default"
    },
    {
      "key": "collectionVersion",
      "value": "1.0.0",
      "type": "default"
    },
    {
      "key": "testEnvironment",
      "value": "development",
      "type": "default"
    }
  ],
  "item": []
}
