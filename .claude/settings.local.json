{
  "permissions": {
    "allow": [
      "Bash(docker --version:*)",
      "Bash(minikube version:*)",
      "Bash(docker compose:*)",
      "Bash(brew install:*)",
      "Bash(k6:*)",
      "Bash(jmeter --version)",
      "Bash(grafana-server --version)",
      "Bash(influxd version:*)",
      "Bash(source venv/bin/activate:*)",
      "Bash(source ../venv/bin/activate)",
      "Bash(head -30 performance-testing-platform/src/utils/*.js)",
      "Bash(head -30 performance-testing-platform/src/middleware/*.js)",
      "WebFetch(domain:github.com)",
      "Bash(sed -i '' 's|actions/checkout@v4|actions/checkout@v5|g' *.yml)",
      "Bash(sed -i '' 's|actions/setup-node@v4|actions/setup-node@v5|g' *.yml)",
      "Bash(sed -i '' 's|actions/upload-artifact@v4|actions/upload-artifact@v5|g' *.yml)",
      "Bash(sed -i '' 's|actions/download-artifact@v4|actions/download-artifact@v5|g' *.yml)",
      "Bash(gh run:*)",
      "Bash(xargs -I{} gh run view {} --log)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Bash(yamllint -d relaxed \"$f\")",
      "Bash(done)",
      "Bash(pip3 install:*)",
      "Bash(source /Users/michaelzhou/Documents/github/michael-zhou-qa-portfolio/venv/bin/activate)",
      "Bash(for action:*)",
      "Bash(curl -s https://api.github.com/repos/actions/checkout/releases)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(do sed:*)",
      "Bash(HOMEBREW_NO_AUTO_UPDATE=1 brew install jmeter 2>&1)",
      "Read(//private/tmp/**)",
      "Bash(lsof -ti:3000)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null || exit 0; changed=$({ git diff --name-only HEAD 2>/dev/null; git ls-files --others --exclude-standard 2>/dev/null; } | sort -u); [ -z \"$changed\" ] && exit 0; suggestions=\"\"; echo \"$changed\" | grep -q '\\.py$' && suggestions=\"pytest\"; echo \"$changed\" | grep -qE '\\.(js|ts|jsx|tsx)$' && { [ -n \"$suggestions\" ] && suggestions=\"$suggestions, npm test\" || suggestions=\"npm test\"; }; echo \"$changed\" | grep -q '.github/workflows/' && { [ -n \"$suggestions\" ] && suggestions=\"$suggestions, check GitHub Actions\" || suggestions=\"check GitHub Actions\"; }; [ -n \"$suggestions\" ] && echo \"{\\\"systemMessage\\\":\\\"Test suggestion: $suggestions\\\"}\" || true",
            "statusMessage": "Checking for test suggestions..."
          }
        ]
      }
    ]
  }
}
