{
  "name": "qa-portfolio-cicd-demo",
  "version": "1.0.0",
  "description": "CI/CD pipeline demonstration project showcasing GitHub Actions, Docker, Cypress, and Newman integration",
  "scripts": {
    "test": "npm run test:cypress && npm run test:newman",
    "test:cypress": "cypress run",
    "test:cypress:headed": "cypress open",
    "test:newman": "newman run postman/api-collection.json -e postman/environment.json -r cli,htmlextra,junit --reporter-htmlextra-export newman/report.html --reporter-junit-export newman/junit.xml",
    "docker:build": "docker compose build",
    "docker:test": "docker compose up -d && docker compose wait cypress newman && docker compose down && npm run docker:cleanup",
    "docker:test:watch": "docker compose up",
    "docker:test:logs": "./scripts/run-regression-test-with-logs.sh",
    "docker:clean": "docker compose down -v",
    "docker:cleanup": "./scripts/fix-permissions.sh",
    "validate": "./scripts/validate-environment.sh",
    "pretest": "./scripts/validate-environment.sh || true",
    "lint": "eslint cypress/**/*.js",
    "lint:fix": "eslint cypress/**/*.js --fix",
    "test:tracked": "./scripts/track-test-execution-simple.sh",
    "dashboard": "./scripts/generate-dashboard.sh && xdg-open test-metrics/dashboard.html",
    "dashboard:generate": "./scripts/generate-dashboard.sh",
    "ci:install": "npm ci",
    "ci:verify": "cypress verify",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:scan": "docker run --rm -v $(pwd):/workspace aquasec/trivy fs --config /workspace/security/trivy-config.yaml /workspace",
    "security:report": "./security/security-report.sh",
    "test:track": "./scripts/track-test-execution.sh",
    "localstack:up": "docker compose -f docker-compose.localstack.yml up -d",
    "localstack:down": "docker compose -f docker-compose.localstack.yml down",
    "localstack:status": "curl -s http://localhost:4566/_localstack/health | python3 -m json.tool",
    "prepare": "husky install || true"
  },
  "keywords": [
    "cypress",
    "newman",
    "postman",
    "ci-cd",
    "testing",
    "automation"
  ],
  "author": "Michael Zhou <michael_zhou@trendmicro.com>",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^13.6.0",
    "eslint": "^8.55.0",
    "eslint-plugin-cypress": "^2.15.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "newman": "^6.1.0",
    "newman-reporter-htmlextra": "^1.23.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "echo 'Formatting not available without prettier'"
    ]
  }
}
