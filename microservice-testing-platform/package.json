{
  "name": "microservice-testing-platform",
  "version": "1.0.0",
  "description": "E-commerce microservice testing platform - Order, Inventory, Payment",
  "private": true,
  "scripts": {
    "lint": "eslint services/ tests/ shared/ --ext .js",
    "lint:fix": "eslint services/ tests/ shared/ --ext .js --fix",
    "format": "prettier --write 'services/**/*.js' 'tests/**/*.js' 'shared/**/*.js'",
    "format:check": "prettier --check 'services/**/*.js' 'tests/**/*.js' 'shared/**/*.js'",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:contract": "jest --testPathPattern=tests/contract",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:observability": "jest --testPathPattern=tests/observability",
    "test:all": "jest --testPathPattern='tests/(unit|contract|integration|e2e|observability)'",
    "test:coverage": "jest --testPathPattern='tests/(unit|contract|integration|e2e|observability)' --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:test": "docker compose up -d && npm run test:e2e && docker compose down"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  }
}
