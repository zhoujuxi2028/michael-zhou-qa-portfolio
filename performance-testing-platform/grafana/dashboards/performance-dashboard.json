{
  "uid": "performance-dashboard",
  "title": "Performance Testing Platform — Phase 7",
  "tags": ["performance", "k6", "phase7"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Distribution (by endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT sum(\"value\") FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval), \"endpoint\"",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Latency Heatmap (p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Custom Metrics — Heap/EventLoop/Orders",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT mean(\"value\") FROM \"server_heap_used_mb\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "legendFormat": "Heap (MB)"
        },
        {
          "refId": "B",
          "query": "SELECT mean(\"value\") FROM \"server_event_loop_lag\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "legendFormat": "EventLoop Lag (ms)"
        },
        {
          "refId": "C",
          "query": "SELECT sum(\"value\") FROM \"soak_order_success\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "legendFormat": "Order Success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Heap (MB)" },
            "properties": [
              {
                "id": "unit",
                "value": "decmbytes"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
