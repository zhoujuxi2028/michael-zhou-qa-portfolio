# SID IAM Testing Platform - Environment Configuration

# SSO Mock Service
SSO_HOST=localhost
SSO_PORT=8000
SSO_SECRET_KEY=test-secret-key-do-not-use-in-production

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# LDAP Mock
LDAP_BASE_DN=dc=university,dc=edu
LDAP_ADMIN_DN=cn=admin,dc=university,dc=edu
LDAP_ADMIN_PASSWORD=admin

# Kerberos Mock
KRB_REALM=UNIVERSITY.EDU
KRB_TGT_LIFETIME_HOURS=10
KRB_ST_LIFETIME_HOURS=1

# Data Warehouse
WAREHOUSE_DB=:memory:

# Logging
LOG_LEVEL=INFO

# Reporting
REPORT_DIR=./reports
REPORT_FORMAT=html
