#!/bin/sh
# pre-commit: Secret scan + lint-staged 委派
#
# 架构（G-08 迁移后）：
#   1. Secret scan（G-01, 内置）—— lint-staged 不负责密钥扫描，需独立完成
#   2. lint-staged —— 按 staged 文件路径触发各项目的 lint
#      规则定义在 root package.json "lint-staged" 字段，当前覆盖：
#        - *.py                               → ruff check + format --check
#        - performance-testing-platform/**/*.js → eslint + prettier --check
#        - api-testing-demo/**/*.js           → eslint（条件：项目已 npm install）
#        - microservice-testing-platform/**/*.js → eslint（条件：项目已 npm install）
#        - playwright-demo/**/*.{js,ts}        → eslint（条件：项目已 npm install）
#        - api-testing-demo/collections/**/*.json → npm run validate
#
# 应急绕过：
#   SKIP_SECRET_SCAN=1  — 跳过 secret scan（管理员审批）
#   SKIP_LINT_STAGED=1  — 跳过 lint-staged（管理员审批）
#   --no-verify         — git 原生全跳过；但 CI commit-guard.yml 仍会拦截
#
# 故障降级：lint-staged 未安装（node_modules 缺失）时输出提示但不阻断（CI 兜底）

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# === [G-01] Secret scan on staged diff ===
if [ "${SKIP_SECRET_SCAN:-0}" != "1" ]; then
    ALLOW_FILE="$REPO_ROOT/.secretsallow"

    STAGED_DIFF=$(git diff --cached --no-color --unified=0 --diff-filter=ACM \
        -- ':(exclude)**/package-lock.json' ':(exclude)**/*.min.js' ':(exclude)**/*.map' \
        | awk '/^\+\+\+ /{ next } /^\+/ { sub(/^\+/, ""); print }' || true)

    if [ -n "$STAGED_DIFF" ]; then
        PATTERNS='(AKIA|ASIA)[0-9A-Z]{16}
aws_secret_access_key[[:space:]]*=[[:space:]]*["'"'"']?[A-Za-z0-9/+=]{40}
gh[poursa]_[A-Za-z0-9]{30,255}
-----BEGIN [A-Z ]*PRIVATE KEY-----
xox[baprsoe]-[A-Za-z0-9-]{10,}
AIza[0-9A-Za-z_-]{35}
eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}
(SECRET|TOKEN|PASSWORD|API_KEY|PRIVATE_KEY)[[:space:]]*[:=][[:space:]]*["'"'"'][^"'"'"'\$\{}<>]{12,}["'"'"']'

        HITS=$(printf '%s\n' "$STAGED_DIFF" | grep -nE "$PATTERNS" || true)

        if [ -n "$HITS" ] && [ -f "$ALLOW_FILE" ]; then
            TMP_ALLOW=$(mktemp)
            grep -vE '^[[:space:]]*(#|$)' "$ALLOW_FILE" > "$TMP_ALLOW" || true
            if [ -s "$TMP_ALLOW" ]; then
                HITS=$(printf '%s\n' "$HITS" | grep -vEf "$TMP_ALLOW" || true)
            fi
            rm -f "$TMP_ALLOW"
        fi

        if [ -n "$HITS" ]; then
            echo ""
            echo "✖ [Secret Scan] 检测到疑似密钥/凭据：" >&2
            printf '%s\n' "$HITS" | head -20 | sed 's/^/     /' >&2
            echo "" >&2
            echo "  处理建议：" >&2
            echo "    1) 从 staged 区移除并改用环境变量 / .env (gitignored)" >&2
            echo "    2) 若为误报，添加正则到 .secretsallow（每行一条）" >&2
            echo "    3) 紧急绕过（需管理员审批）：SKIP_SECRET_SCAN=1 git commit ..." >&2
            exit 1
        fi
        echo "✔ Secret scan 通过"
    fi
fi

# === [G-08] Delegate to lint-staged ===
if [ "${SKIP_LINT_STAGED:-0}" = "1" ]; then
    echo "⚠  SKIP_LINT_STAGED=1 已启用，跳过 lint-staged"
    exit 0
fi

if [ -x "$REPO_ROOT/node_modules/.bin/lint-staged" ]; then
    exec npx --no-install lint-staged --concurrent false
else
    echo "⚠  lint-staged 未安装（缺少 node_modules）"
    echo "   请在仓库根执行 'npm install' 以启用完整的 lint 门控"
    echo "   本次 commit 将继续（CI commit-guard.yml 会兜底）"
    exit 0
fi
