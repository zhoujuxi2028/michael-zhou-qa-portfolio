#!/bin/sh
# Validate Postman files on commit
cd api-testing-demo && npm run validate
cd ..

# Lint Python files with ruff
CHANGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' | grep -v 'venv/')
if [ -n "$CHANGED_PY" ]; then
    echo "Running ruff on staged Python files..."
    ./venv/bin/ruff check $CHANGED_PY
    ./venv/bin/ruff format --check $CHANGED_PY
fi

# Lint + format check JS files in performance-testing-platform
# 使用递归 pathspec（**/*.js）覆盖任意层级，避免单层 glob 漏检
# （历史问题：PR #218 中 tests/unit/scripts/*.js 因单层 glob 未被拦截 → CI prettier 红灯）
CHANGED_JS=$(git diff --cached --name-only --diff-filter=ACM -- \
    'performance-testing-platform/src/**/*.js' \
    'performance-testing-platform/tests/**/*.js' \
    'performance-testing-platform/scripts/**/*.js')
if [ -n "$CHANGED_JS" ]; then
    # 钩子在仓库根触发，但 eslint/prettier 配置在子目录；将路径改为相对子目录
    REL_JS=$(echo "$CHANGED_JS" | sed 's|^performance-testing-platform/||')
    (
        cd performance-testing-platform || exit 1
        echo "Running eslint on staged JS files (performance-testing-platform)..."
        # shellcheck disable=SC2086
        npx --no-install eslint $REL_JS || exit 1
        echo "Running prettier --check on staged JS files (performance-testing-platform)..."
        # shellcheck disable=SC2086
        npx --no-install prettier --check $REL_JS || exit 1
    ) || exit 1
fi
