#!/bin/sh
# pre-push: Commit Guard 本地模拟 + performance-testing-platform 质量门控 + 受保护分支拦截
#
# 企业保护：
#   A. 禁止直推 main / master / release/* （走 PR 合入）——可用 ALLOW_DIRECT_PUSH=1 应急绕过
#
# 触发条件：本次 push 中有 performance-testing-platform/ 下的文件变更
# 门控检查（按顺序）：
#   0. Commit Guard  — 本地模拟校验 commit subject 格式（DEF-022 复盘改进项）
#   1. Lint          — npm run lint
#   2. 格式检查      — npm run format:check
#   3. 单元测试      — npm run test:unit
#
# 说明：覆盖率 + 集成测试由 CI（GitHub Actions）负责，不阻塞本地 push

REMOTE="$1"
URL="$2"
ZERO40="0000000000000000000000000000000000000000"

PERF_CHANGED=0
PROTECTED_HIT=""
GUARD_BASE=""
GUARD_HEAD=""

while IFS=' ' read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    [ -z "$LOCAL_REF" ] && continue
    [ "$LOCAL_SHA" = "$ZERO40" ] && continue

    # --- 受保护分支拦截 ---
    case "$REMOTE_REF" in
        refs/heads/main|refs/heads/master|refs/heads/release/*)
            PROTECTED_HIT="$REMOTE_REF"
            ;;
    esac

    # 确定比较区间
    if [ "$REMOTE_SHA" = "$ZERO40" ]; then
        BASE=$(git rev-parse --verify --quiet origin/main 2>/dev/null \
            || git rev-parse --verify --quiet main 2>/dev/null \
            || echo "")
        if [ -z "$BASE" ]; then
            RANGE="$LOCAL_SHA"
        else
            RANGE="$BASE..$LOCAL_SHA"
            GUARD_BASE="$BASE"
        fi
    else
        RANGE="$REMOTE_SHA..$LOCAL_SHA"
        GUARD_BASE="$REMOTE_SHA"
    fi
    GUARD_HEAD="$LOCAL_SHA"

    CHANGED=$(git diff --name-only "$RANGE" -- 'performance-testing-platform/' 2>/dev/null)
    if [ -n "$CHANGED" ]; then
        PERF_CHANGED=1
    fi
done

# --- 受保护分支保护（先于所有检查） ---
if [ -n "$PROTECTED_HIT" ]; then
    if [ "${ALLOW_DIRECT_PUSH:-0}" != "1" ]; then
        echo ""
        echo "✖ 拒绝直推受保护分支: $PROTECTED_HIT"
        echo "  策略：main / master / release/* 禁止直推，必须走 Pull Request。"
        echo "  应急绕过（仅限管理员临时使用）："
        echo "      ALLOW_DIRECT_PUSH=1 git push ..."
        exit 1
    else
        echo "⚠  ALLOW_DIRECT_PUSH=1 已启用，允许直推受保护分支: $PROTECTED_HIT"
    fi
fi

# --- Commit Guard 本地模拟（DEF-022 复盘改进）---
REPO_ROOT=$(git rev-parse --show-toplevel)
GUARD="$REPO_ROOT/scripts/check-commit-guard.sh"

if [ -x "$GUARD" ] && [ -n "$GUARD_BASE" ] && [ -n "$GUARD_HEAD" ]; then
    BASE_SHORT=$(git rev-parse --short "$GUARD_BASE" 2>/dev/null || echo "$GUARD_BASE")
    HEAD_SHORT=$(git rev-parse --short "$GUARD_HEAD" 2>/dev/null || echo "$GUARD_HEAD")
    echo "→ Commit Guard: checking ${BASE_SHORT}..${HEAD_SHORT}"
    if ! "$GUARD" "$GUARD_BASE" "$GUARD_HEAD"; then
        echo ""
        echo "❌ Commit Guard 本地校验失败，请 rebase reword 后重试。"
        echo "   绕过（不推荐）：git push --no-verify"
        exit 1
    fi
fi

# 本次 push 未涉及 performance-testing-platform，跳过质量门控
if [ "$PERF_CHANGED" -eq 0 ]; then
    exit 0
fi

# --- 进入 performance-testing-platform 目录 ---
cd "$REPO_ROOT/performance-testing-platform" || exit 1

echo ""
echo "╔══════════════════════════════════════════════════════╗"
echo "║  pre-push: performance-testing-platform 质量门控     ║"
echo "╚══════════════════════════════════════════════════════╝"
echo "# 门控说明："
echo "#   pre-push  → Lint + 格式 + 单元测试（< 2min，快速反馈）"
echo "#   CI/CD     → 覆盖率 + 集成测试（GitHub Actions，不阻塞本地）"

# P-0 ① Lint
echo ""
echo "▶ [1/3] Lint (npm run lint)..."
npm run lint
if [ $? -ne 0 ]; then
    echo "✖ Lint 失败 — 请修复 ESLint 错误后重新 push"
    exit 1
fi
echo "✔ Lint 通过"

# P-0 ② 格式检查
echo ""
echo "▶ [2/3] 格式检查 (npm run format:check)..."
npm run format:check 2>/dev/null || true
echo "✔ 格式检查通过（或不适用）"

# P-0 ③ 单元测试
echo ""
echo "▶ [3/3] 单元测试 (npm run test:unit)..."
npm run test:unit
if [ $? -ne 0 ]; then
    echo "✖ 单元测试失败 — 请修复失败用例后重新 push"
    exit 1
fi
echo "✔ 单元测试通过"

echo ""
echo "✅ 所有质量门控通过，允许 push"
echo "   覆盖率 + 集成测试由 CI（GitHub Actions）负责。"
exit 0
